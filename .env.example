# HTTP port the app listens on
PORT=3000

# MariaDB connection — defaults to the bundled compose 'db' service
# To use a remote MariaDB, set DB_HOST to your remote host and remove the 'db' compose service
DB_HOST=db
DB_PORT=3306
DB_USER=civmc
DB_PASSWORD=changeme
DB_NAME=civmc
DB_ROOT_PASSWORD=rootchangeme

# Signing secret for session cookies — use a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Discord OAuth application (create at https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Must match the redirect URI configured in your Discord app
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Your Discord user ID — your account gets is_admin=true on first boot
SUPERADMIN_DISCORD_ID=your_discord_user_id

# Absolute base URL of the site (used in OAuth redirects and links)
PUBLIC_BASE_URL=http://localhost:3000
